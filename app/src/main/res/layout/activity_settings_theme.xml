<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?attr/colorSurface">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/settingsToolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="56dp"
        android:paddingHorizontal="16dp"
        app:title="@string/settings_theme"
        app:titleTextColor="?attr/colorOnSurface"
        app:titleCentered="true"
        app:navigationIcon="@drawable/ic_back"
        app:navigationIconTint="?attr/colorOnSurfaceVariant" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <RadioGroup
                android:id="@+id/themeRadioGroup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/comp_surface_xl"
                android:padding="16dp">

                <com.google.android.material.radiobutton.MaterialRadioButton
                    android:id="@+id/radioLight"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:text="@string/theme_light"
                    android:textAppearance="?attr/textAppearanceBodyLarge"
                    android:textColor="?attr/colorOnSurface" />

                <com.google.android.material.radiobutton.MaterialRadioButton
                    android:id="@+id/radioDark"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:text="@string/theme_dark"
                    android:textAppearance="?attr/textAppearanceBodyLarge"
                    android:textColor="?attr/colorOnSurface" />

                <com.google.android.material.radiobutton.MaterialRadioButton
                    android:id="@+id/radioAmoled"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:text="@string/theme_amoled"
                    android:textAppearance="?attr/textAppearanceBodyLarge"
                    android:textColor="?attr/colorOnSurface" />

                <com.google.android.material.radiobutton.MaterialRadioButton
                    android:id="@+id/radioCustom"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:text="@string/theme_custom"
                    android:textAppearance="?attr/textAppearanceBodyLarge"
                    android:textColor="?attr/colorOnSurface" />

            </RadioGroup>

            <!-- Customize Theme Section -->
            <LinearLayout
                android:id="@+id/sectionCustomize"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="@string/customize_theme_section"
                    android:textAppearance="?attr/textAppearanceLabelLarge"
                    android:textColor="?attr/colorPrimary" />

                <LinearLayout
                    android:id="@+id/btnOpenEditor"
                    android:layout_width="match_parent"
                    android:layout_height="72dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/comp_surface_xl_clickable"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="20dp">
                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_appearance"
                        android:contentDescription="@string/theme_editor_title"
                        app:tint="?attr/colorOnSurfaceVariant" />
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="20dp"
                        android:layout_weight="1"
                        android:text="@string/theme_editor_title"
                        android:textAppearance="?attr/textAppearanceTitleMedium"
                        android:textColor="?attr/colorOnSurface"
                        android:fontFamily="sans-serif-medium" />
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_chevron_right_apple"
                        app:tint="?attr/colorOnSurfaceVariant" />
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
