<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:padding="16dp">

    <!-- Circular D-pad Ring -->
    <FrameLayout
        android:id="@+id/dpadRing"
        android:layout_width="220dp"
        android:layout_height="220dp"
        android:background="@drawable/apple_button_bg"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Directional Click Areas -->
        <View
            android:id="@+id/btnDpadUp"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:layout_gravity="top"
            android:background="?attr/selectableItemBackgroundBorderless" />

        <View
            android:id="@+id/btnDpadDown"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:layout_gravity="bottom"
            android:background="?attr/selectableItemBackgroundBorderless" />

        <View
            android:id="@+id/btnDpadLeft"
            android:layout_width="80dp"
            android:layout_height="match_parent"
            android:layout_gravity="start"
            android:background="?attr/selectableItemBackgroundBorderless" />

        <View
            android:id="@+id/btnDpadRight"
            android:layout_width="80dp"
            android:layout_height="match_parent"
            android:layout_gravity="end"
            android:background="?attr/selectableItemBackgroundBorderless" />

        <!-- Direction Dots -->
        <View
            android:layout_width="6dp"
            android:layout_height="6dp"
            android:layout_gravity="top|center_horizontal"
            android:layout_marginTop="16dp"
            android:background="@drawable/apple_button_bg"
            android:backgroundTint="?attr/colorOnSurfaceVariant" />

        <View
            android:layout_width="6dp"
            android:layout_height="6dp"
            android:layout_gravity="bottom|center_horizontal"
            android:layout_marginBottom="16dp"
            android:background="@drawable/apple_button_bg"
            android:backgroundTint="?attr/colorOnSurfaceVariant" />

        <View
            android:layout_width="6dp"
            android:layout_height="6dp"
            android:layout_gravity="start|center_vertical"
            android:layout_marginStart="16dp"
            android:background="@drawable/apple_button_bg"
            android:backgroundTint="?attr/colorOnSurfaceVariant" />

        <View
            android:layout_width="6dp"
            android:layout_height="6dp"
            android:layout_gravity="end|center_vertical"
            android:layout_marginEnd="16dp"
            android:background="@drawable/apple_button_bg"
            android:backgroundTint="?attr/colorOnSurfaceVariant" />

        <!-- Center Select Button -->
        <View
            android:id="@+id/btnDpadOk"
            android:layout_width="86dp"
            android:layout_height="86dp"
            android:layout_gravity="center"
            android:background="@drawable/apple_button_bg" />

        <!-- Small center dot -->
        <View
            android:layout_width="4dp"
            android:layout_height="4dp"
            android:layout_gravity="center"
            android:background="@drawable/apple_button_bg"
            android:backgroundTint="?attr/colorOnSurface" />

    </FrameLayout>

    <!-- Bottom Row of Buttons -->
    <LinearLayout
        android:id="@+id/remoteBottomRow"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:orientation="horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/dpadRing">

        <ImageButton
            android:id="@+id/btnRemoteRewind"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:background="@drawable/apple_button_bg"
            android:contentDescription="@string/touchpad_rewind_button"
            android:padding="16dp"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_rewind"
            app:tint="?attr/colorOnSurface" />

        <ImageButton
            android:id="@+id/btnRemotePlayPause"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:background="@drawable/apple_button_bg"
            android:contentDescription="@string/touchpad_play_pause_button"
            android:padding="16dp"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_play_pause_apple"
            app:tint="?attr/colorOnSurface" />

        <ImageButton
            android:id="@+id/btnRemoteFastForward"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:background="@drawable/apple_button_bg"
            android:contentDescription="@string/touchpad_fast_forward_button"
            android:padding="16dp"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_fast_forward"
            app:tint="?attr/colorOnSurface" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
