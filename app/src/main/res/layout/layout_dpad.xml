<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:padding="16dp">

    <!-- Circular D-pad Ring -->
    <FrameLayout
        android:id="@+id/dpadRing"
        android:layout_width="220dp"
        android:layout_height="220dp"
        android:background="@drawable/comp_tonal_shape_oval"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Directional Click Areas -->
        <View
            android:id="@+id/btnDpadUp"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:layout_gravity="top"
            android:background="?attr/selectableItemBackgroundBorderless" />

        <View
            android:id="@+id/btnDpadDown"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:layout_gravity="bottom"
            android:background="?attr/selectableItemBackgroundBorderless" />

        <View
            android:id="@+id/btnDpadLeft"
            android:layout_width="80dp"
            android:layout_height="match_parent"
            android:layout_gravity="start"
            android:background="?attr/selectableItemBackgroundBorderless" />

        <View
            android:id="@+id/btnDpadRight"
            android:layout_width="80dp"
            android:layout_height="match_parent"
            android:layout_gravity="end"
            android:background="?attr/selectableItemBackgroundBorderless" />

        <!-- Subtle Directional Icons (Modern MD3 approach) -->
        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_gravity="top|center_horizontal"
            android:layout_marginTop="20dp"
            android:src="@drawable/ic_arrow_up"
            android:importantForAccessibility="no"
            app:tint="?attr/colorOnSurfaceVariant"
            android:alpha="0.6" />

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_gravity="bottom|center_horizontal"
            android:layout_marginBottom="20dp"
            android:src="@drawable/ic_arrow_down"
            android:importantForAccessibility="no"
            app:tint="?attr/colorOnSurfaceVariant"
            android:alpha="0.6" />

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_gravity="start|center_vertical"
            android:layout_marginStart="20dp"
            android:src="@drawable/ic_arrow_left"
            android:importantForAccessibility="no"
            app:tint="?attr/colorOnSurfaceVariant"
            android:alpha="0.6" />

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_gravity="end|center_vertical"
            android:layout_marginEnd="20dp"
            android:src="@drawable/ic_arrow_right"
            android:importantForAccessibility="no"
            app:tint="?attr/colorOnSurfaceVariant"
            android:alpha="0.6" />

        <!-- Center Select Button -->
        <View
            android:id="@+id/btnDpadOk"
            android:layout_width="86dp"
            android:layout_height="86dp"
            android:layout_gravity="center"
            android:background="@drawable/comp_tonal_shape_oval"
            android:backgroundTint="?attr/colorSurfaceContainerHighest" />

    </FrameLayout>

    <!-- Bottom Row of Buttons -->
    <LinearLayout
        android:id="@+id/remoteBottomRow"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="28dp"
        android:orientation="horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/dpadRing">

        <ImageButton
            android:id="@+id/btnRemoteRewind"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:background="@drawable/comp_tonal_shape_oval"
            android:contentDescription="@string/touchpad_rewind_button"
            android:padding="16dp"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_rewind"
            app:tint="?attr/colorOnSurface" />

        <ImageButton
            android:id="@+id/btnRemotePlayPause"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:background="@drawable/comp_tonal_shape_oval"
            android:contentDescription="@string/touchpad_play_pause_button"
            android:padding="16dp"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_play_pause"
            app:tint="?attr/colorOnSurface" />

        <ImageButton
            android:id="@+id/btnRemoteFastForward"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:background="@drawable/comp_tonal_shape_oval"
            android:contentDescription="@string/touchpad_fast_forward_button"
            android:padding="16dp"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_fast_forward"
            app:tint="?attr/colorOnSurface" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
