<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?attr/colorSurface">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/settingsToolbar"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:minHeight="64dp"
        android:paddingHorizontal="12dp"
        app:title="@string/theme_editor_title"
        app:titleCentered="true"
        app:titleTextAppearance="?attr/textAppearanceHeadlineSmall"
        app:titleTextColor="?attr/colorOnSurface"
        app:contentInsetStartWithNavigation="0dp"
        app:navigationIcon="@drawable/ic_back"
        app:navigationIconTint="?attr/colorOnSurfaceVariant" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:overScrollMode="never"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="40dp">

            <!-- Monochrome Mode -->
            <LinearLayout
                android:id="@+id/rowMonochrome"
                android:layout_width="match_parent"
                android:layout_height="68dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="24dp"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/theme_monochrome_title"
                        android:textAppearance="?attr/textAppearanceBodyLarge"
                        android:textColor="?attr/colorOnSurface" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/theme_monochrome_summary"
                        android:textAppearance="?attr/textAppearanceBodySmall"
                        android:textColor="?attr/colorOnSurfaceVariant" />
                </LinearLayout>

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switchMonochrome"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <!-- Group: Surfaces -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:layout_marginHorizontal="24dp"
                android:layout_marginBottom="8dp"
                android:text="@string/theme_group_surfaces"
                android:textAppearance="?attr/textAppearanceLabelLarge"
                android:textColor="?attr/colorPrimary" />
            <LinearLayout android:id="@+id/containerSurfaces" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" />

            <!-- Group: Content -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:layout_marginHorizontal="24dp"
                android:layout_marginBottom="8dp"
                android:text="@string/theme_group_text"
                android:textAppearance="?attr/textAppearanceLabelLarge"
                android:textColor="?attr/colorPrimary" />
            <LinearLayout android:id="@+id/containerContent" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" />

            <!-- Group: Accent -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:layout_marginHorizontal="24dp"
                android:layout_marginBottom="8dp"
                android:text="@string/theme_group_accent"
                android:textAppearance="?attr/textAppearanceLabelLarge"
                android:textColor="?attr/colorPrimary" />
            <LinearLayout android:id="@+id/containerAccent" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" />

            <!-- Group: System UI -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:layout_marginHorizontal="24dp"
                android:layout_marginBottom="8dp"
                android:text="@string/theme_group_system_ui"
                android:textAppearance="?attr/textAppearanceLabelLarge"
                android:textColor="?attr/colorPrimary" />
            <LinearLayout android:id="@+id/containerSystemUI" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" />

            <!-- Live Preview -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="40dp"
                android:layout_marginHorizontal="24dp"
                android:layout_marginBottom="12dp"
                android:text="@string/theme_group_live_preview"
                android:textAppearance="?attr/textAppearanceLabelLarge"
                android:textColor="?attr/colorPrimary" />

            <include
                android:id="@+id/layoutPreview"
                layout="@layout/view_theme_preview"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="24dp" />

            <!-- Load Presets Section -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="40dp"
                android:layout_marginHorizontal="24dp"
                android:layout_marginBottom="12dp"
                android:text="@string/theme_group_load"
                android:textAppearance="?attr/textAppearanceLabelLarge"
                android:textColor="?attr/colorPrimary" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="24dp"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnResetLight"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    style="@style/Widget.Material3.Button.TonalButton"
                    android:text="@string/theme_preset_light"
                    app:cornerRadius="20dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnResetDark"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    style="@style/Widget.Material3.Button.TonalButton"
                    android:text="@string/theme_preset_dark"
                    app:cornerRadius="20dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnResetAmoled"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    style="@style/Widget.Material3.Button.TonalButton"
                    android:text="@string/theme_preset_amoled"
                    app:cornerRadius="20dp" />
            </LinearLayout>

            <!-- Export / Import -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:paddingHorizontal="24dp"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnExport"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    style="@style/Widget.Material3.Button.TonalButton"
                    android:text="@string/theme_btn_export"
                    app:cornerRadius="20dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnImport"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    style="@style/Widget.Material3.Button.TonalButton"
                    android:text="@string/theme_btn_import"
                    app:cornerRadius="20dp" />
            </LinearLayout>

            <!-- Final Action: Reset All -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnResetAll"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="16dp"
                android:layout_marginHorizontal="24dp"
                style="@style/Widget.Material3.Button.TextButton"
                android:text="@string/theme_btn_reset_all"
                android:textColor="?attr/colorError" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>
